\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces Image Classification vs.~Object Localization: Classification (left) answers ``Is this a dog?'' and outputs a class label; Localization (right) answers ``Where is the dog?'' and outputs class label plus a bounding box. Detection extends localization to multiple objects. (Source: CV Module 3)}}{35}{figure.caption.35}\protected@file@percent }
\newlabel{fig:m3_cls_vs_loc}{{36}{35}{Image Classification vs.~Object Localization: Classification (left) answers ``Is this a dog?'' and outputs a class label; Localization (right) answers ``Where is the dog?'' and outputs class label plus a bounding box. Detection extends localization to multiple objects. (Source: CV Module 3)}{figure.caption.35}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Types of Object Detection}{35}{subsection.3.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.1}Two-Stage Object Detection (Region Proposal-Based)}{35}{subsubsection.3.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.2}One-Stage Object Detection (End-to-End, No Proposals)}{36}{subsubsection.3.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.2.3}Proposal-Free / Transformer-Based Detection}{36}{subsubsection.3.2.3}\protected@file@percent }

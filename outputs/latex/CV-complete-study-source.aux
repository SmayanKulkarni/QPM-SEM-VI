\@writefile{toc}{\contentsline {subsection}{\numberline {4.6}Advanced GAN Variants}{52}{subsection.4.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {58}{\ignorespaces DCGAN Architecture: Generator (top) --- $100$-d noise $\to $ reshape $\to $ successive FSC (fractionally-strided conv / transposed conv) layers upsampling $4\times 4\times 1024 \to 64\times 64\times 3$. Discriminator (bottom) --- mirror of generator using strided convolutions downsampling $64\times 64\times 3 \to $ single real/fake score. (Source: CV Module 4)}}{52}{figure.caption.55}\protected@file@percent }
\newlabel{fig:m4_dcgan}{{58}{52}{DCGAN Architecture: Generator (top) --- $100$-d noise $\to $ reshape $\to $ successive FSC (fractionally-strided conv / transposed conv) layers upsampling $4\times 4\times 1024 \to 64\times 64\times 3$. Discriminator (bottom) --- mirror of generator using strided convolutions downsampling $64\times 64\times 3 \to $ single real/fake score. (Source: CV Module 4)}{figure.caption.55}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {59}{\ignorespaces Conditional GAN (CGAN): Real images, class labels, and noise are all fed to the Discriminator; noise + labels are fed to the Generator. The label conditions both networks so the generator produces images of a specific requested class. (Source: CV Module 4)}}{53}{figure.caption.56}\protected@file@percent }
\newlabel{fig:m4_cgan}{{59}{53}{Conditional GAN (CGAN): Real images, class labels, and noise are all fed to the Discriminator; noise + labels are fed to the Generator. The label conditions both networks so the generator produces images of a specific requested class. (Source: CV Module 4)}{figure.caption.56}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {60}{\ignorespaces DCGAN Training Progress: Digit grids at 10k, 20k, 50k, and 100k training steps show how the generator improves from noise to recognisable and diverse digit images over training. (Source: CV Module 4)}}{53}{figure.caption.57}\protected@file@percent }
\newlabel{fig:m4_dcgan_train}{{60}{53}{DCGAN Training Progress: Digit grids at 10k, 20k, 50k, and 100k training steps show how the generator improves from noise to recognisable and diverse digit images over training. (Source: CV Module 4)}{figure.caption.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {61}{\ignorespaces Fr\'{e}chet Inception Distance (FID) formula: $\text  {FID} \approx (\mu _r - \mu _f)^2 + (\sigma _r - \sigma _f)^2$ where $\mu _r, \sigma _r$ are mean and std of real image features and $\mu _f, \sigma _f$ are mean and std of fake image features from an Inception network. Lower FID = better quality. (Source: CV Module 4)}}{53}{figure.caption.58}\protected@file@percent }
\newlabel{fig:m4_fid}{{61}{53}{Fr\'{e}chet Inception Distance (FID) formula: $\text {FID} \approx (\mu _r - \mu _f)^2 + (\sigma _r - \sigma _f)^2$ where $\mu _r, \sigma _r$ are mean and std of real image features and $\mu _f, \sigma _f$ are mean and std of fake image features from an Inception network. Lower FID = better quality. (Source: CV Module 4)}{figure.caption.58}{}}

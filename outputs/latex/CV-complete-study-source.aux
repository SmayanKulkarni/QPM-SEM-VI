\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.1}R-CNN (Region-based CNN)}{36}{subsubsection.3.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {37}{\ignorespaces R-CNN (Region-based CNN) Pipeline: Input image $\to $ Selective Search generates ~2000 region proposals $\to $ each proposal is resized and passed individually through a CNN $\to $ feature vector fed into SVMs for classification (Car? Dog? Bike?) and linear regression for bounding box refinement. (Source: CV Module 3)}}{37}{figure.caption.36}\protected@file@percent }
\newlabel{fig:m3_rcnn}{{37}{37}{R-CNN (Region-based CNN) Pipeline: Input image $\to $ Selective Search generates ~2000 region proposals $\to $ each proposal is resized and passed individually through a CNN $\to $ feature vector fed into SVMs for classification (Car? Dog? Bike?) and linear regression for bounding box refinement. (Source: CV Module 3)}{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {38}{\ignorespaces One-Stage vs.~Two-Stage Object Detection comparison: Two-stage (Faster R-CNN, Mask R-CNN) achieves higher accuracy via a separate proposal step; one-stage (YOLO, SSD) is faster and suited for real-time use. (Source: CV Module 3)}}{37}{figure.caption.37}\protected@file@percent }
\newlabel{fig:m3_stage_compare}{{38}{37}{One-Stage vs.~Two-Stage Object Detection comparison: Two-stage (Faster R-CNN, Mask R-CNN) achieves higher accuracy via a separate proposal step; one-stage (YOLO, SSD) is faster and suited for real-time use. (Source: CV Module 3)}{figure.caption.37}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.2}Fast R-CNN}{37}{subsubsection.3.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {39}{\ignorespaces Fast R-CNN Pipeline: The entire image is passed once through a Backbone CNN (e.g., VGG) to produce a shared feature map; Selective Search proposals are projected onto this map; RoI Pooling extracts fixed $7\times 7$ features per region; two FC layers produce class scores and bounding box offsets in parallel. (Source: CV Module 3)}}{38}{figure.caption.38}\protected@file@percent }
\newlabel{fig:m3_fast_rcnn}{{39}{38}{Fast R-CNN Pipeline: The entire image is passed once through a Backbone CNN (e.g., VGG) to produce a shared feature map; Selective Search proposals are projected onto this map; RoI Pooling extracts fixed $7\times 7$ features per region; two FC layers produce class scores and bounding box offsets in parallel. (Source: CV Module 3)}{figure.caption.38}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.3}Faster R-CNN}{38}{subsubsection.3.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {40}{\ignorespaces Region Proposal Network (RPN): A $3\times 3$ sliding window sweeps the conv feature map; for each position, $k$ anchor boxes of varying scales/ratios are evaluated. A 256-d intermediate layer feeds into two heads: \textit  {cls} layer ($2k$ objectness scores: object/background) and \textit  {reg} layer ($4k$ box-regression coordinates). NMS retains top proposals. (Source: CV Module 3)}}{38}{figure.caption.39}\protected@file@percent }
\newlabel{fig:m3_rpn}{{40}{38}{Region Proposal Network (RPN): A $3\times 3$ sliding window sweeps the conv feature map; for each position, $k$ anchor boxes of varying scales/ratios are evaluated. A 256-d intermediate layer feeds into two heads: \textit {cls} layer ($2k$ objectness scores: object/background) and \textit {reg} layer ($4k$ box-regression coordinates). NMS retains top proposals. (Source: CV Module 3)}{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {41}{\ignorespaces Faster R-CNN full workflow: RPN takes anchors and CNN features $\to $ Region Proposal Layer $\to $ NMS filters top anchors $\to $ RoI Pooling $\to $ parallel Classifier (object or background?) and Regressor (refined bounding box). (Source: CV Module 3)}}{39}{figure.caption.40}\protected@file@percent }
\newlabel{fig:m3_faster_rcnn}{{41}{39}{Faster R-CNN full workflow: RPN takes anchors and CNN features $\to $ Region Proposal Layer $\to $ NMS filters top anchors $\to $ RoI Pooling $\to $ parallel Classifier (object or background?) and Regressor (refined bounding box). (Source: CV Module 3)}{figure.caption.40}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {42}{\ignorespaces Bounding Box Regression Transform: Given a region proposal $(p_x,p_y,p_h,p_w)$, the network predicts transforms $(t_x,t_y,t_h,t_w)$. Translation: $b_x = p_x + p_w t_w$, $b_y = p_y + p_h t_h$. Log-space scale: $b_w = p_w e^{t_w}$, $b_h = p_h e^{t_h}$. (Source: CV Module 3)}}{40}{figure.caption.41}\protected@file@percent }
\newlabel{fig:m3_bbox_transform}{{42}{40}{Bounding Box Regression Transform: Given a region proposal $(p_x,p_y,p_h,p_w)$, the network predicts transforms $(t_x,t_y,t_h,t_w)$. Translation: $b_x = p_x + p_w t_w$, $b_y = p_y + p_h t_h$. Log-space scale: $b_w = p_w e^{t_w}$, $b_h = p_h e^{t_h}$. (Source: CV Module 3)}{figure.caption.41}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {43}{\ignorespaces R-CNN evolution: From R-CNN (2000 separate CNN passes) to Fast R-CNN (one CNN pass + RoI pooling) to Faster R-CNN (RPN shares features with detector).}}{40}{figure.43}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}YOLO (You Only Look Once)}{40}{subsection.3.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.1}YOLO Grid Prediction}{40}{subsubsection.3.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {44}{\ignorespaces YOLO grid-based detection: Image divided into $S \times S$ grid cells. Cells containing object centers (green) predict bounding boxes; empty cells (gray) predict background.}}{41}{figure.44}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.2}Anchor Boxes}{41}{subsubsection.3.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {45}{\ignorespaces YOLO Predictions (YOLOv5 Nano): Bounding boxes with class labels and confidence scores overlaid on the input image in a single forward pass --- truck (0.98), dogs, person, teddy, sheep detected simultaneously. (Source: CV Module 3)}}{41}{figure.caption.42}\protected@file@percent }
\newlabel{fig:m3_yolo_pred}{{45}{41}{YOLO Predictions (YOLOv5 Nano): Bounding boxes with class labels and confidence scores overlaid on the input image in a single forward pass --- truck (0.98), dogs, person, teddy, sheep detected simultaneously. (Source: CV Module 3)}{figure.caption.42}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {46}{\ignorespaces RPN with Anchor Boxes and NMS: Conv feature map $\to $ $3\times 3\times 256$ conv $\to $ feature vector $\to $ cls layer outputs $2k$ objectness scores and reg layer outputs $4k$ coordinates for $k$ anchor boxes; NMS post-processes to keep top proposals. (Source: CV Module 3)}}{42}{figure.caption.43}\protected@file@percent }
\newlabel{fig:m3_rpn_nms}{{46}{42}{RPN with Anchor Boxes and NMS: Conv feature map $\to $ $3\times 3\times 256$ conv $\to $ feature vector $\to $ cls layer outputs $2k$ objectness scores and reg layer outputs $4k$ coordinates for $k$ anchor boxes; NMS post-processes to keep top proposals. (Source: CV Module 3)}{figure.caption.43}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.3}YOLO Loss Function}{42}{subsubsection.3.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {47}{\ignorespaces TP/FP classification table for YOLO detections: Predictions sorted by confidence; each is matched against ground truth via IoU threshold. TP = correct detection; FP = wrong detection. Used as input to compute Precision--Recall curve and mAP. (Source: CV Module 3)}}{43}{figure.caption.44}\protected@file@percent }
\newlabel{fig:m3_tp_fp}{{47}{43}{TP/FP classification table for YOLO detections: Predictions sorted by confidence; each is matched against ground truth via IoU threshold. TP = correct detection; FP = wrong detection. Used as input to compute Precision--Recall curve and mAP. (Source: CV Module 3)}{figure.caption.44}{}}

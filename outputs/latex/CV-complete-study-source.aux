\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Morphological operations concept: Original binary object, after erosion (shrinks), after dilation (expands), and the structuring element (3$\times $3 kernel).}}{12}{figure.9}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {1.5.2}Morphological Algorithms}{12}{subsubsection.1.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Erosion effect on the letter ``M'': the four panels show (top-left) original binary object, (top-right) after erosion the object shrinks and thin parts break, (bottom-left) after stronger erosion even more detail is lost, (bottom-right) erosion removes noise while preserving larger structures. (Source: CV Module 1, Slide 39)}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:m1_erosion_letter}{{10}{13}{Erosion effect on the letter ``M'': the four panels show (top-left) original binary object, (top-right) after erosion the object shrinks and thin parts break, (bottom-left) after stronger erosion even more detail is lost, (bottom-right) erosion removes noise while preserving larger structures. (Source: CV Module 1, Slide 39)}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces All four basic morphological operations on digit ``3'': (a) original binary image; (b) erosion --- object shrinks; (c) dilation --- object expands; (d) opening (erosion then dilation) --- removes small noise; (e) closing (dilation then erosion) --- fills small holes. (Source: CV Module 1, Slide 45, dspguide.com)}}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:m1_morphological_ops}{{11}{13}{All four basic morphological operations on digit ``3'': (a) original binary image; (b) erosion --- object shrinks; (c) dilation --- object expands; (d) opening (erosion then dilation) --- removes small noise; (e) closing (dilation then erosion) --- fills small holes. (Source: CV Module 1, Slide 45, dspguide.com)}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {1.6}Preprocessing Challenges and Solutions}{14}{subsection.1.6}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {2}Module 2: Shape Analysis, Edge Detection, and Segmentation}{15}{section.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}Introduction to Shape Analysis}{15}{subsection.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Shape analysis challenge --- Occlusion: (top) a face is progressively occluded by a book across three frames (0005, 0519, 0835), requiring the tracker to infer the partially hidden face shape; (bottom) a person is occluded by other pedestrians in a crowd scene. These examples show why shape descriptions must be robust to partial visibility. (Source: CV Module 2, Slide 10)}}{15}{figure.caption.11}\protected@file@percent }
\newlabel{fig:m2_occlusion}{{12}{15}{Shape analysis challenge --- Occlusion: (top) a face is progressively occluded by a book across three frames (0005, 0519, 0835), requiring the tracker to infer the partially hidden face shape; (bottom) a person is occluded by other pedestrians in a crowd scene. These examples show why shape descriptions must be robust to partial visibility. (Source: CV Module 2, Slide 10)}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Two approaches to shape description: Contour-Based methods (left gear, blue) focus strictly on boundary pixels --- fast but moderately robust; Region-Based methods (right gear, orange) use all pixels inside the object --- slower but highly robust to noise and occlusion. (Source: CV Module 2, Slide 41)}}{16}{figure.caption.12}\protected@file@percent }
\newlabel{fig:m2_contour_vs_region}{{13}{16}{Two approaches to shape description: Contour-Based methods (left gear, blue) focus strictly on boundary pixels --- fast but moderately robust; Region-Based methods (right gear, orange) use all pixels inside the object --- slower but highly robust to noise and occlusion. (Source: CV Module 2, Slide 41)}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Comparison of shape representation methods: Chain Code and Fourier are contour-based (use only boundary pixels), suited to boundary tracing and recognition; Moments, Convex Hull, and Skeleton are region-based, using all interior pixels, suited to classification, defect analysis, and structural matching. (Source: CV Module 2, Slide 55)}}{16}{figure.caption.13}\protected@file@percent }
\newlabel{fig:m2_methods_comparison}{{14}{16}{Comparison of shape representation methods: Chain Code and Fourier are contour-based (use only boundary pixels), suited to boundary tracing and recognition; Moments, Convex Hull, and Skeleton are region-based, using all interior pixels, suited to classification, defect analysis, and structural matching. (Source: CV Module 2, Slide 55)}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Shape invariance requirement: the same airplane object shown in its original pose, rotated, and scaled-and-translated must all produce the same shape descriptor output ``Airplane''. Good shape descriptors are invariant to rotation, scale, and translation. (Source: CV Module 2, Slide 40)}}{17}{figure.caption.14}\protected@file@percent }
\newlabel{fig:m2_shape_invariants}{{15}{17}{Shape invariance requirement: the same airplane object shown in its original pose, rotated, and scaled-and-translated must all produce the same shape descriptor output ``Airplane''. Good shape descriptors are invariant to rotation, scale, and translation. (Source: CV Module 2, Slide 40)}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Contour-Based Shape Representation}{17}{subsection.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Contour-Based Methods --- defining the boundary: the leaf outline (blue border) illustrates the core logic of tracing only the boundary pixels without filling the interior. Primary domains: OCR, signature detection, shape matching. (Source: CV Module 2, Slide 42)}}{17}{figure.caption.15}\protected@file@percent }
\newlabel{fig:m2_contour_intro}{{16}{17}{Contour-Based Methods --- defining the boundary: the leaf outline (blue border) illustrates the core logic of tracing only the boundary pixels without filling the interior. Primary domains: OCR, signature detection, shape matching. (Source: CV Module 2, Slide 42)}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Contour representation of the letter ``S'': (a) original binary image; (b) simple contour trace --- inner and outer boundary; (c) morphological gradient highlighting the boundary region; (d) external boundary points (red dots around the convex outline); (e) exact boundary points (red dots following the actual letter outline). (Source: CV Module 2, Slide 12)}}{18}{figure.caption.16}\protected@file@percent }
\newlabel{fig:m2_contour_S}{{17}{18}{Contour representation of the letter ``S'': (a) original binary image; (b) simple contour trace --- inner and outer boundary; (c) morphological gradient highlighting the boundary region; (d) external boundary points (red dots around the convex outline); (e) exact boundary points (red dots following the actual letter outline). (Source: CV Module 2, Slide 12)}{figure.caption.16}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.2.1}Chain Codes (Freeman Chain Codes)}{18}{subsubsection.2.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces 8-directional Freeman chain code compass: directions 0--7 emanating from the current pixel (centre asterisk). Direction 0 = right, 1 = upper-right, 2 = up, 3 = upper-left, 4 = left, 5 = lower-left, 6 = down, 7 = lower-right. (Source: CV Module 2, Slide 16)}}{19}{figure.caption.17}\protected@file@percent }
\newlabel{fig:m2_chaincode_compass}{{18}{19}{8-directional Freeman chain code compass: directions 0--7 emanating from the current pixel (centre asterisk). Direction 0 = right, 1 = upper-right, 2 = up, 3 = upper-left, 4 = left, 5 = lower-left, 6 = down, 7 = lower-right. (Source: CV Module 2, Slide 16)}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Chain code setup: (a) a diagonal contour traced from its initial point with direction arrows; (b) the 8-direction compass numbered 0--7. The chain code for this contour encodes which direction arrow is followed at each boundary pixel step. (Source: CV Module 2, Slide 16)}}{19}{figure.caption.18}\protected@file@percent }
\newlabel{fig:m2_chaincode_contour}{{19}{19}{Chain code setup: (a) a diagonal contour traced from its initial point with direction arrows; (b) the 8-direction compass numbered 0--7. The chain code for this contour encodes which direction arrow is followed at each boundary pixel step. (Source: CV Module 2, Slide 16)}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces 4-directional and 8-directional chain codes (Gonzalez \& Woods): the object boundary (top-left) is resampled onto a coarser grid (top-right, ``boundary vertices''); the 4-directional chain code (bottom-left) traces the object using only horizontal/vertical steps, while the 8-directional code (bottom-right) also includes diagonals for a more compact representation. (Source: CV Module 2, Slide 24)}}{20}{figure.caption.19}\protected@file@percent }
\newlabel{fig:m2_chaincode_4dir8dir}{{20}{20}{4-directional and 8-directional chain codes (Gonzalez \& Woods): the object boundary (top-left) is resampled onto a coarser grid (top-right, ``boundary vertices''); the 4-directional chain code (bottom-left) traces the object using only horizontal/vertical steps, while the 8-directional code (bottom-right) also includes diagonals for a more compact representation. (Source: CV Module 2, Slide 24)}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces Worked chain code example: the object boundary (irregular staircase shape on the grid, right) is traced from the starting cell. The 8-directional compass (left) defines direction numbers; the resulting chain code is ``0066002200666444646464422222''. (Source: CV Module 2, Slide 23)}}{20}{figure.caption.20}\protected@file@percent }
\newlabel{fig:m2_chaincode_worked}{{21}{20}{Worked chain code example: the object boundary (irregular staircase shape on the grid, right) is traced from the starting cell. The 8-directional compass (left) defines direction numbers; the resulting chain code is ``0066002200666444646464422222''. (Source: CV Module 2, Slide 23)}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces Step-by-step chain code tracing: starting at pixel $p$ (blue), the first move is direction 0 (right), and the chain code begins ``0''. The grid and 8-direction compass show how each successive boundary pixel contributes one code digit. (Source: CV Module 2, Slide 26)}}{21}{figure.caption.21}\protected@file@percent }
\newlabel{fig:m2_chaincode_step}{{22}{21}{Step-by-step chain code tracing: starting at pixel $p$ (blue), the first move is direction 0 (right), and the chain code begins ``0''. The grid and 8-direction compass show how each successive boundary pixel contributes one code digit. (Source: CV Module 2, Slide 26)}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces Complete chain code example on a ring-shaped contour: the traced boundary with direction arrows yields chain code ``0, 0, 7, 7, 5, 6, 5, 5, 4, 3, 2, 2, 2, 1, 2''. The 8-direction compass is shown top-right. (Source: CV Module 2, Slide 27)}}{21}{figure.caption.22}\protected@file@percent }
\newlabel{fig:m2_chaincode_ring}{{23}{21}{Complete chain code example on a ring-shaped contour: the traced boundary with direction arrows yields chain code ``0, 0, 7, 7, 5, 6, 5, 5, 4, 3, 2, 2, 2, 1, 2''. The 8-direction compass is shown top-right. (Source: CV Module 2, Slide 27)}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces Chain code --- change of starting point: the same L-shaped contour traced from two different starting pixels produces different chain codes (CC: 03032211 vs 03221103). The shape is identical but the code sequence differs, hence normalization is needed for start-point invariance. (Source: CV Module 2, Slide 18)}}{22}{figure.caption.23}\protected@file@percent }
\newlabel{fig:m2_cc_start}{{24}{22}{Chain code --- change of starting point: the same L-shaped contour traced from two different starting pixels produces different chain codes (CC: 03032211 vs 03221103). The shape is identical but the code sequence differs, hence normalization is needed for start-point invariance. (Source: CV Module 2, Slide 18)}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces Chain code --- rotation sensitivity: the same L-shape rotated 90° produces a completely different chain code (CC: 10033212 vs original), demonstrating that simple chain codes are NOT rotation invariant. The Circular First Difference normalizes this. (Source: CV Module 2, Slide 20)}}{22}{figure.caption.24}\protected@file@percent }
\newlabel{fig:m2_cc_rotation}{{25}{22}{Chain code --- rotation sensitivity: the same L-shape rotated 90° produces a completely different chain code (CC: 10033212 vs original), demonstrating that simple chain codes are NOT rotation invariant. The Circular First Difference normalizes this. (Source: CV Module 2, Slide 20)}{figure.caption.24}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.2.2}Fourier Descriptors}{23}{subsubsection.2.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Fourier descriptor reconstruction with increasing coefficients $P$: starting from only $P=2$ coefficients (rough oval), adding more coefficients progressively recovers the detail of the original boundary ($K=64$). This demonstrates the frequency-to-detail relationship: low-$P$ = coarse shape; high-$P$ = fine shape. (Source: CV Module 2, Slide 33)}}{24}{figure.caption.25}\protected@file@percent }
\newlabel{fig:m2_fourier_recon}{{26}{24}{Fourier descriptor reconstruction with increasing coefficients $P$: starting from only $P=2$ coefficients (rough oval), adding more coefficients progressively recovers the detail of the original boundary ($K=64$). This demonstrates the frequency-to-detail relationship: low-$P$ = coarse shape; high-$P$ = fine shape. (Source: CV Module 2, Slide 33)}{figure.caption.25}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.2.3}Geometric Border Representation and B-Splines}{24}{subsubsection.2.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces Geometric border representation: the shape boundary is approximated by connecting sampled control points with straight line segments. Concept: replaces curves with line segments; benefit: low memory, fast matching; use case: robotics and industrial inspection. (Source: CV Module 2, Slide 37)}}{25}{figure.caption.26}\protected@file@percent }
\newlabel{fig:m2_geom_borders}{{27}{25}{Geometric border representation: the shape boundary is approximated by connecting sampled control points with straight line segments. Concept: replaces curves with line segments; benefit: low memory, fast matching; use case: robotics and industrial inspection. (Source: CV Module 2, Slide 37)}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces B-Spline boundary representation: the shape boundary (top) is smoothed through control points via B-spline curves; the physical analogy (bottom) is a thin flexible rod (spline) constrained by pins. Concept: smooths the curve using control points; use case: medical organ modelling and animation. (Source: CV Module 2, Slide 38)}}{26}{figure.caption.27}\protected@file@percent }
\newlabel{fig:m2_bspline}{{28}{26}{B-Spline boundary representation: the shape boundary (top) is smoothed through control points via B-spline curves; the physical analogy (bottom) is a thin flexible rod (spline) constrained by pins. Concept: smooths the curve using control points; use case: medical organ modelling and animation. (Source: CV Module 2, Slide 38)}{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.2.4}Shape Invariants}{26}{subsubsection.2.2.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Region-Based Shape Representation}{26}{subsection.2.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.1}Scalar Region Descriptors}{26}{subsubsection.2.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces Compactness formula: $C = P^2 / A$ where $P$ is the perimeter and $A$ is the area. A perfect circle has minimum compactness; elongated or irregular shapes have higher compactness values. Used as a shape invariant in region-based classification. (Source: CV Module 2, Slide 45)}}{27}{figure.caption.28}\protected@file@percent }
\newlabel{fig:m2_compactness}{{29}{27}{Compactness formula: $C = P^2 / A$ where $P$ is the perimeter and $A$ is the area. A perfect circle has minimum compactness; elongated or irregular shapes have higher compactness values. Used as a shape invariant in region-based classification. (Source: CV Module 2, Slide 45)}{figure.caption.28}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.2}Moments}{27}{subsubsection.2.3.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.3}Convex Hull}{27}{subsubsection.2.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces Convex hull of a hand: the orange polygon is the tightest convex envelope around the hand outline. The concavities between fingers are ``hull defects'' and are used in finger-counting and gesture recognition algorithms. (Source: CV Module 2, Slide 48)}}{28}{figure.caption.29}\protected@file@percent }
\newlabel{fig:m2_convex_hull}{{30}{28}{Convex hull of a hand: the orange polygon is the tightest convex envelope around the hand outline. The concavities between fingers are ``hull defects'' and are used in finger-counting and gesture recognition algorithms. (Source: CV Module 2, Slide 48)}{figure.caption.29}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.4}Region Skeletons}{28}{subsubsection.2.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces Region skeletonization (top): an S-shaped thick region is reduced to its one-pixel-wide medial axis (centerline) while preserving topology --- used for fingerprint matching. Region Adjacency Graph / RAG (bottom): a landscape image divided into land, sea, and sky regions is represented as a graph where nodes are regions and edges connect adjacent neighbours --- used for satellite scene understanding. (Source: CV Module 2, Slide 50)}}{28}{figure.caption.30}\protected@file@percent }
\newlabel{fig:m2_skeleton_rag}{{31}{28}{Region skeletonization (top): an S-shaped thick region is reduced to its one-pixel-wide medial axis (centerline) while preserving topology --- used for fingerprint matching. Region Adjacency Graph / RAG (bottom): a landscape image divided into land, sea, and sky regions is represented as a graph where nodes are regions and edges connect adjacent neighbours --- used for satellite scene understanding. (Source: CV Module 2, Slide 50)}{figure.caption.30}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.5}Region Decomposition}{29}{subsubsection.2.3.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.3.6}Region Neighborhood Graph (RNG)}{29}{subsubsection.2.3.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {32}{\ignorespaces Region Neighborhood Graph (RNG): an image segmented into 8 regions (R1--R8, left) is converted to a graph (right) where each node represents a region and each red edge connects two spatially adjacent regions. This structure enables scene-level reasoning about spatial relationships between objects. (Source: CV Module 2, Slide 54)}}{29}{figure.caption.31}\protected@file@percent }
\newlabel{fig:m2_rng}{{32}{29}{Region Neighborhood Graph (RNG): an image segmented into 8 regions (R1--R8, left) is converted to a graph (right) where each node represents a region and each red edge connects two spatially adjacent regions. This structure enables scene-level reasoning about spatial relationships between objects. (Source: CV Module 2, Slide 54)}{figure.caption.31}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}Thresholding and Segmentation}{29}{subsection.2.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.4.1}Thresholding}{29}{subsubsection.2.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces Illumination normalization pipeline for face images: an input face under uneven lighting is processed by an illuminant direction estimation block, which feeds into an Improved Retinex algorithm to produce a normalized output face with balanced illumination. This is a key preprocessing step before thresholding or segmentation. (Source: CV Module 2, Slide 61)}}{30}{figure.caption.32}\protected@file@percent }
\newlabel{fig:m2_illum_norm}{{33}{30}{Illumination normalization pipeline for face images: an input face under uneven lighting is processed by an illuminant direction estimation block, which feeds into an Improved Retinex algorithm to produce a normalized output face with balanced illumination. This is a key preprocessing step before thresholding or segmentation. (Source: CV Module 2, Slide 61)}{figure.caption.32}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.4.2}Global Thresholding (Iterative Method)}{30}{subsubsection.2.4.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.4.3}Otsu's Method}{31}{subsubsection.2.4.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Region-Based Segmentation}{31}{subsection.2.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.5.1}Region Growing}{31}{subsubsection.2.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces Image segmentation pipeline: input scene (top-left) is processed through two paths --- simple edge map (top-middle) or occlusion-boundary-aware edge map (bottom-middle) --- each fed into Normalized Cuts (Ncut) segmentation to produce colour-labelled region maps. The occlusion-aware path gives more semantically correct regions. (Source: CV Module 2, Slide 12)}}{32}{figure.caption.33}\protected@file@percent }
\newlabel{fig:m2_seg_pipeline}{{34}{32}{Image segmentation pipeline: input scene (top-left) is processed through two paths --- simple edge map (top-middle) or occlusion-boundary-aware edge map (bottom-middle) --- each fed into Normalized Cuts (Ncut) segmentation to produce colour-labelled region maps. The occlusion-aware path gives more semantically correct regions. (Source: CV Module 2, Slide 12)}{figure.caption.33}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.5.2}Region Splitting and Merging}{32}{subsubsection.2.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.6}Pixel Connectivity}{32}{subsection.2.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces Pixel connectivity decision flowchart: given two pixels, first check 4-connectivity (side-adjacent $\to $ connected); if not, check diagonal adjacency; if diagonal and they share a common 4-neighbour with value 1, they are m-connected (avoids false diagonal merges); otherwise not connected. (Source: CV Module 2, Slide 81)}}{33}{figure.caption.34}\protected@file@percent }
\newlabel{fig:m2_pixel_conn}{{35}{33}{Pixel connectivity decision flowchart: given two pixels, first check 4-connectivity (side-adjacent $\to $ connected); if not, check diagonal adjacency; if diagonal and they share a common 4-neighbour with value 1, they are m-connected (avoids false diagonal merges); otherwise not connected. (Source: CV Module 2, Slide 81)}{figure.caption.34}{}}

\@writefile{lof}{\contentsline {figure}{\numberline {49}{\ignorespaces RoI Pooling: A $17\times 17$ feature region is quantized to stride $= \lfloor 17/7\rfloor = 2$ and max-pooled to a fixed $7\times 7$ output. Quantization introduces misalignment. (Source: CV Module 3)}}{46}{figure.caption.46}\protected@file@percent }
\newlabel{fig:m3_roi_pool}{{49}{46}{RoI Pooling: A $17\times 17$ feature region is quantized to stride $= \lfloor 17/7\rfloor = 2$ and max-pooled to a fixed $7\times 7$ output. Quantization introduces misalignment. (Source: CV Module 3)}{figure.caption.46}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {50}{\ignorespaces RoI Align: Unlike RoI Pooling, the stride is NOT quantized (stride $= 17/7 = 2.42$ kept as float). Bilinear interpolation at fractional grid points (using the four nearest neighbours $Q_{11}, Q_{21}, Q_{12}, Q_{22}$) eliminates quantization misalignment, critical for Mask R-CNN pixel-level predictions. (Source: CV Module 3)}}{46}{figure.caption.47}\protected@file@percent }
\newlabel{fig:m3_roi_align}{{50}{46}{RoI Align: Unlike RoI Pooling, the stride is NOT quantized (stride $= 17/7 = 2.42$ kept as float). Bilinear interpolation at fractional grid points (using the four nearest neighbours $Q_{11}, Q_{21}, Q_{12}, Q_{22}$) eliminates quantization misalignment, critical for Mask R-CNN pixel-level predictions. (Source: CV Module 3)}{figure.caption.47}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.8}Mask R-CNN}{47}{subsection.3.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {51}{\ignorespaces Mask R-CNN = Faster R-CNN + Mask Head: Feature map $\to $ RoIAlign extracts aligned region features $\to $ two conv layers (Mask Head) predict a per-class binary mask in parallel with the existing class and box heads. Enables instance segmentation (each person gets a unique colour mask). (Source: CV Module 3)}}{47}{figure.caption.48}\protected@file@percent }
\newlabel{fig:m3_mask_rcnn}{{51}{47}{Mask R-CNN = Faster R-CNN + Mask Head: Feature map $\to $ RoIAlign extracts aligned region features $\to $ two conv layers (Mask Head) predict a per-class binary mask in parallel with the existing class and box heads. Enables instance segmentation (each person gets a unique colour mask). (Source: CV Module 3)}{figure.caption.48}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.9}Semantic vs.~Instance Segmentation}{47}{subsection.3.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {52}{\ignorespaces Semantic segmentation (left) labels all pixels of the same class identically (all buildings share one colour). Instance segmentation (right) distinguishes individual instances of the same class (Building 1, Building 2, \ldots  {} each get a unique colour). (Source: CV Module 3)}}{47}{figure.caption.49}\protected@file@percent }
\newlabel{fig:m3_sem_vs_inst}{{52}{47}{Semantic segmentation (left) labels all pixels of the same class identically (all buildings share one colour). Instance segmentation (right) distinguishes individual instances of the same class (Building 1, Building 2, \ldots {} each get a unique colour). (Source: CV Module 3)}{figure.caption.49}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.10}Face Recognition: Siamese Networks}{48}{subsection.3.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {53}{\ignorespaces Siamese Network Architecture: Two identical CNNs (shared weights) process two input face images independently into 128-d embedding vectors; Euclidean distance $\sqrt  {\DOTSB \sum@ \slimits@ (a-b)^2}$ between embeddings determines similarity. Small distance $\Rightarrow $ same person; large distance $\Rightarrow $ different person. (Source: CV Module 3)}}{48}{figure.caption.50}\protected@file@percent }
\newlabel{fig:m3_siamese}{{53}{48}{Siamese Network Architecture: Two identical CNNs (shared weights) process two input face images independently into 128-d embedding vectors; Euclidean distance $\sqrt {\sum (a-b)^2}$ between embeddings determines similarity. Small distance $\Rightarrow $ same person; large distance $\Rightarrow $ different person. (Source: CV Module 3)}{figure.caption.50}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {54}{\ignorespaces Training a Siamese Network: Two images ($x_1$, $x_2$) pass through shared function $f$ to produce embeddings $h_1$, $h_2$; combined via dense layers $\to $ sigmoid similarity score $\text  {sim}(x_1,x_2)$; compared with target label (1 = same class) to compute loss via backpropagation. (Source: CV Module 3)}}{48}{figure.caption.51}\protected@file@percent }
\newlabel{fig:m3_siamese_train}{{54}{48}{Training a Siamese Network: Two images ($x_1$, $x_2$) pass through shared function $f$ to produce embeddings $h_1$, $h_2$; combined via dense layers $\to $ sigmoid similarity score $\text {sim}(x_1,x_2)$; compared with target label (1 = same class) to compute loss via backpropagation. (Source: CV Module 3)}{figure.caption.51}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.11}Zero-Shot, One-Shot, and Few-Shot Learning}{49}{subsection.3.11}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {55}{\ignorespaces Comparison of Zero-Shot (ZSL), One-Shot (OSL), and Few-Shot (FSL) Learning: ZSL uses attributes or general knowledge with no labelled examples; OSL uses embedding-based comparison (e.g., FaceNet) with one image per class; FSL uses meta-learning with 2--10 images per class. (Source: CV Module 3)}}{49}{figure.caption.52}\protected@file@percent }
\newlabel{fig:m3_zsl}{{55}{49}{Comparison of Zero-Shot (ZSL), One-Shot (OSL), and Few-Shot (FSL) Learning: ZSL uses attributes or general knowledge with no labelled examples; OSL uses embedding-based comparison (e.g., FaceNet) with one image per class; FSL uses meta-learning with 2--10 images per class. (Source: CV Module 3)}{figure.caption.52}{}}

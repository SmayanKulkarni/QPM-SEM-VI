\@writefile{lof}{\contentsline {figure}{\numberline {48}{\ignorespaces Cumulative Precision--Recall table: Detections sorted by confidence; cumulative TP and FP are tracked; Precision = TP/(TP+FP) and Recall = TP/Total GT are computed at each step to plot the Precision--Recall curve and calculate Average Precision (AP). (Source: CV Module 3)}}{44}{figure.caption.45}\protected@file@percent }
\newlabel{fig:m3_pr_table}{{48}{44}{Cumulative Precision--Recall table: Detections sorted by confidence; cumulative TP and FP are tracked; Precision = TP/(TP+FP) and Recall = TP/Total GT are computed at each step to plot the Precision--Recall curve and calculate Average Precision (AP). (Source: CV Module 3)}{figure.caption.45}{}}

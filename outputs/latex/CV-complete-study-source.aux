\@writefile{lof}{\contentsline {figure}{\numberline {70}{\ignorespaces Brightness Constancy Assumption: A pixel at $(x,y)$ in frame $t$ moves to $(x+dx, y+dy)$ in frame $t+dt$ but its intensity remains constant: $f(x,y,t) = f(x+dx,y+dy,t+dt)$. This constraint underlies all optical flow methods. (Source: CV Module 6)}}{65}{figure.caption.67}\protected@file@percent }
\newlabel{fig:m6_bright_const}{{70}{65}{Brightness Constancy Assumption: A pixel at $(x,y)$ in frame $t$ moves to $(x+dx, y+dy)$ in frame $t+dt$ but its intensity remains constant: $f(x,y,t) = f(x+dx,y+dy,t+dt)$. This constraint underlies all optical flow methods. (Source: CV Module 6)}{figure.caption.67}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {71}{\ignorespaces Lucas-Kanade vs.~Horn-Schunck Comparison: LK is local (small window), produces sparse flow, faster, good for corners; HS is global (entire image), produces dense flow, slower, smooth and continuous. (Source: CV Module 6)}}{66}{figure.caption.68}\protected@file@percent }
\newlabel{fig:m6_lk_vs_hs}{{71}{66}{Lucas-Kanade vs.~Horn-Schunck Comparison: LK is local (small window), produces sparse flow, faster, good for corners; HS is global (entire image), produces dense flow, slower, smooth and continuous. (Source: CV Module 6)}{figure.caption.68}{}}

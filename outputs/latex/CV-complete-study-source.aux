\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Preprocessing effect on image quality: left --- blurred image with low spatial detail; right --- sharp image after contrast-preserving restoration. This demonstrates why preprocessing is essential before analysis. (Source: CV Module 1, Slide 24)}}{9}{figure.caption.5}\protected@file@percent }
\newlabel{fig:m1_blur_vs_sharp}{{5}{9}{Preprocessing effect on image quality: left --- blurred image with low spatial detail; right --- sharp image after contrast-preserving restoration. This demonstrates why preprocessing is essential before analysis. (Source: CV Module 1, Slide 24)}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Salt-and-pepper noise: original image (left) vs. image corrupted by random black and white pixel noise (right). Median filtering is the standard preprocessing technique to remove this type of noise. (Source: CV Module 1, Slide 26)}}{9}{figure.caption.6}\protected@file@percent }
\newlabel{fig:m1_salt_pepper}{{6}{9}{Salt-and-pepper noise: original image (left) vs. image corrupted by random black and white pixel noise (right). Median filtering is the standard preprocessing technique to remove this type of noise. (Source: CV Module 1, Slide 26)}{figure.caption.6}{}}

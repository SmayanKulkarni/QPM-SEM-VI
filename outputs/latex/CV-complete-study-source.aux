\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Image segmentation example: the original traffic scene (left) is divided into colour-coded regions --- each car is assigned a distinct colour label in the segmented output (right). (Source: CV Module 1, Slide 28)}}{10}{figure.caption.7}\protected@file@percent }
\newlabel{fig:m1_segmentation_example}{{7}{10}{Image segmentation example: the original traffic scene (left) is divided into colour-coded regions --- each car is assigned a distinct colour label in the segmented output (right). (Source: CV Module 1, Slide 28)}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Semantic segmentation of a street scene: every pixel is labelled by class (person, cyclist, car, road, building). Unlike bounding-box detection, segmentation provides pixel-level understanding. (Source: CV Module 1, Slide 29)}}{10}{figure.caption.8}\protected@file@percent }
\newlabel{fig:m1_semantic_segmentation}{{8}{10}{Semantic segmentation of a street scene: every pixel is labelled by class (person, cyclist, car, road, building). Unlike bounding-box detection, segmentation provides pixel-level understanding. (Source: CV Module 1, Slide 29)}{figure.caption.8}{}}
